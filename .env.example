# Pantera bootstrap configuration.
#
# This file documents the ONLY two values supplied via the environment.
# ALL real secrets (database_url, redis_url, anthropic_api_key / openai_api_key,
# and later service tokens) live exclusively in Vault and are fetched at startup
# by load_secrets_from_vault(). Never put real secret values in this file or any
# committed file.

# Address of the Vault container (dev mode in docker-compose).
VAULT_ADDR=http://vault:8200

# Vault token. In dev mode "root" is a well-known, non-sensitive convention.
# In production the platform secret manager holds ONLY this token.
VAULT_TOKEN=root
